EXECUTION_MODE=trace

USER_ADDRESS=0xYourTargetWalletAddress
MONGO_URI=mongodb://localhost:27017/polymarket_copytrading

# 通用建议参数
FETCH_INTERVAL=1
# 冷启动时向前回看多少秒的活动；优先使用此新变量
INITIAL_SYNC_LOOKBACK_SECOND=1
RETRY_LIMIT=3

TRACE_ID=default
TRACE_INITIAL_BALANCE=60

# 可选：高级同步与确认参数
ACTIVITY_SYNC_LIMIT=300
ACTIVITY_SYNC_OVERLAP_MS=30000
SNAPSHOT_STALE_AFTER_MS=30000
ORDER_CONFIRMATION_TIMEOUT_MS=45000
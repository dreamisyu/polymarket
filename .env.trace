# 执行模式：live 为真实跟单，trace 为本地模拟记账
EXECUTION_MODE=trace
# 模拟账户标识，会体现在 trace 集合名与日志中
TRACE_ID=default
# 模拟初始资金（USDC）
TRACE_INITIAL_BALANCE=60
# 目标钱包地址
USER_ADDRESS=0xd0d6053c3c37e727402d84c14069780d360993aa
# 钱包地址
PROXY_WALLET=0x2Ea96F35446ae68B78D587CF16755D3EabcC09A8

CLOB_HTTP_URL=https://clob.polymarket.com
CLOB_WS_URL=wss://clob-ws.polymarket.com
MONGO_URI=mongodb://127.0.0.1:27017/polymarket_copytrading_trace
RPC_URL=https://polygon.drpc.org
USDC_CONTRACT_ADDRESS=0x2791Bca1f2de4661ED88A30C99A7a9449Aa84174
# 可选配置
FETCH_INTERVAL=1
TOO_OLD_TIMESTAMP=0
RETRY_LIMIT=3

# 执行模式：live 为真实跟单，trace 为本地模拟记账
EXECUTION_MODE=live
# 模拟账户标识，会体现在 trace 集合名与日志中
TRACE_ID=default
# 模拟初始资金（USDC）
TRACE_INITIAL_BALANCE=1000
USER_ADDRESS=0xYourTargetWalletAddress
PROXY_WALLET=0xYourProxyWalletAddress
PRIVATE_KEY=abc678def4567890abcdef1234567890abcdef1234567890abcdef1234567890 # 真实模式下的交易钱包私钥
CLOB_HTTP_URL=https://clob.polymarket.com
CLOB_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market
USER_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/user
MONGO_URI=mongodb://localhost:27017/polymarket_copytrading
RPC_URL=https://polygon.drpc.org
USDC_CONTRACT_ADDRESS=0x2791Bca1f2de4661ED88A30C99A7a9449Aa84174
FETCH_INTERVAL=1
TOO_OLD_TIMESTAMP=24
RETRY_LIMIT=3
MAX_SLIPPAGE_BPS=300
MAX_ORDER_USDC=0
PROCESSING_LEASE_MS=30000
ORDER_CONFIRMATION_TIMEOUT_MS=45000
ORDER_CONFIRMATION_POLL_MS=2000
ORDER_CONFIRMATION_BLOCKS=2
ACTIVITY_SYNC_LIMIT=500
ACTIVITY_SYNC_OVERLAP_MS=30000
SNAPSHOT_STALE_AFTER_MS=30000
MARKET_CACHE_TTL_MS=3000
MARKET_WS_RECONNECT_MS=1000
USER_WS_RECONNECT_MS=1000
MARKET_WS_SNAPSHOT_WAIT_MS=750
MARKET_WS_ENABLED=true

# 运行模式：paper=本地账本模拟；live=真实下单
RUN_MODE=paper
# fixed_amount=固定金额；mirror=镜像跟单；proportional=按比例缩放；signal=信号票据
STRATEGY_KIND=fixed_amount

# 日志
LOG_LEVEL=info
LOG_FILE_PATH=logs/bot-paper.log

# 必填：SOURCE_WALLET=你的执行钱包，TARGET_WALLET=被跟单目标钱包
# 建议 paper/live 使用不同数据库，避免互相污染
SOURCE_WALLET=0xYourOwnWalletAddress
TARGET_WALLET=0xLeaderWalletAddress
MONGO_URI=mongodb://localhost:27017/polymarket_copytrading_paper

# 监控与派发
MONITOR_INTERVAL_MS=1000
MONITOR_INITIAL_LOOKBACK_MS=0
MONITOR_OVERLAP_MS=0
ACTIVITY_SYNC_LIMIT=80
ACTIVITY_ADJACENT_MERGE_WINDOW_MS=1000
SNAPSHOT_STALE_AFTER_MS=10000
COPYTRADE_DISPATCH_CONCURRENCY=3
COPYTRADE_PROCESSING_LEASE_MS=300000
RETRY_BACKOFF_MS=200
MAX_RETRY_COUNT=2

# 市场过滤与时效
# 逗号分隔；留空或 all 表示不过滤
# 注意：内置 special 值 crypto_updown_5m 当前内建匹配 BTC / ETH 5 分钟 Up/Down。
# 如果你要进一步限制到单一币种，直接写 slug/关键字更稳妥。
MARKET_WHITELIST=all
# 仅过滤源钱包 BUY 事件；单位 USDC；0 表示不过滤
MIN_SOURCE_BUY_USDC=1
# 迟到买单直接跳过；0 表示关闭
MAX_SIGNAL_AGE_MS=10000

# fixed_amount 策略
FIXED_TRADE_USDC=1
MAX_OPEN_POSITIONS=30
MAX_ACTIVE_EXPOSURE_USDC=25

# proportional 策略
# 0.5 = 跟单 50%；1 = 跟单 100%；1.5 = 跟单 150%
# 仅当 STRATEGY_KIND=proportional 时必填
# PROPORTIONAL_COPY_RATIO=0.5

# signal 策略专用；只有 STRATEGY_KIND=signal 时才需要开启/调整
# SIGNAL_MARKET_SCOPE=all
# SIGNAL_WEAK_THRESHOLD_USDC=50
# SIGNAL_NORMAL_THRESHOLD_USDC=100
# SIGNAL_STRONG_THRESHOLD_USDC=250
# SIGNAL_WEAK_TICKET_USDC=10
# SIGNAL_NORMAL_TICKET_USDC=25
# SIGNAL_STRONG_TICKET_USDC=50

# 下单规划与盘口约束
MAX_SLIPPAGE_BPS=800
MAX_ORDER_USDC=50
# off=不处理尾单；defer=保留到下轮；trim=裁剪本轮
BUY_DUST_RESIDUAL_MODE=trim

# 结算
AUTO_REDEEM_ENABLED=true
SETTLEMENT_INTERVAL_MS=30000
SETTLEMENT_MAX_TASKS_PER_RUN=8
# live 模式下是否真的发链上 redeem 交易
LIVE_SETTLEMENT_ONCHAIN_REDEEM_ENABLED=false

# paper 模式专用：本地账本初始余额
PAPER_INITIAL_BALANCE=25

# 行情 websocket / 订单簿快照
MARKET_WS_RECONNECT_MS=1000
USER_WS_RECONNECT_MS=1000
WS_HEARTBEAT_MS=10000
MARKET_BOOK_STALE_MS=500
MARKET_WS_BOOTSTRAP_WAIT_MS=1000

# live 下单确认 / 节流
LIVE_ORDER_MIN_INTERVAL_MS=0
LIVE_CONFIRM_TIMEOUT_MS=30000
LIVE_RECONCILE_AFTER_TIMEOUT_MS=30000
ORDER_CONFIRMATION_TIMEOUT_MS=30000
ORDER_CONFIRMATION_POLL_MS=2000
ORDER_CONFIRMATION_BLOCKS=2

# live 模式必填
# CLOB_SIGNATURE_TYPE：EOA=普通外部钱包；PROXY=email/Google 登录代理钱包；SAFE=常见代理钱包 / Safe
CLOB_SIGNATURE_TYPE=PROXY
# SAFE / PROXY 时必填；EOA 时留空
PROXY_WALLET=0xYourProxyWalletAddress
# 必须是 64 位十六进制字符串；可带或不带 0x
PRIVATE_KEY=abc678def4567890abcdef1234567890abcdef1234567890abcdef1234567890
# 建议显式配置稳定的 Polygon RPC；不填时代码默认使用 https://polygon.drpc.org
RPC_URL=https://polygon.drpc.org
USDC_CONTRACT_ADDRESS=0x2791Bca1f2de4661ED88A30C99A7a9449Aa84174
CTF_CONTRACT_ADDRESS=0x4d97dcd97ec945f40cf65f87097ace5ea0476045

# 可选：覆盖官方基础设施地址
# CLOB_HTTP_URL=https://clob.polymarket.com
# DATA_API_URL=https://data-api.polymarket.com
# GAMMA_API_URL=https://gamma-api.polymarket.com
# CLOB_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market
# USER_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/user
